{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Didascalie",
  "version": "../package.json",
  "identifier": "io.github.clementpla.didascalie",

  "build": {
    "frontendDist": "../dist/client/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npm run ng serve -o --debug",
    "beforeBuildCommand": "npm run ng build --prod"
  },
  "app": {
    "windows": [
      {
        "title": "Didascalie",
        "width": 1600,
        "height": 1000,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self' 'wasm-unsafe-eval' 'unsafe-eval'; worker-src 'self' blob:; connect-src 'self' ipc: http://ipc.localhost",
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ClementPla/Didascalie/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU4MTM2NjFGMTY2NjM2QjkKUldTNU5tWVdIMllUV01KZGh5aDFZYVVOQXNnTzJoUnArVWVZVm1Dd1Fhd2c2RDRFTTdsU2pFSVcK"
    }
  }
}
