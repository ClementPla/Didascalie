{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "LabelMed",
  "version": "0.3.5",
  "identifier": "io.github.clementpla.labelmed",

  "build": {
    "frontendDist": "../dist/client/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npm run ng serve -o --debug",
    "beforeBuildCommand": "npm run ng build --prod"
  },
  "app": {
    "windows": [
      {
        "title": "Annotator",
        "width": 1600,
        "height": 1000,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; script-src 'self' 'wasm-unsafe-eval'; worker-src 'self' blob:; connect-src 'self' ipc: http://ipc.localhost",
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
